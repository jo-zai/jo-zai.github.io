--information:Created by ڈùچك

tempo =  obj.track0
asp = obj.track1
sizumi = obj.track2
aburi = obj.check0

function kisuuDesu(suuji)
  return (( suuji % 2 ) == 1)
end

function gachideShine(aaa)
  if (aaa == true) then
    return 1
  else
    return 0
  end
end

obj.oy = obj.oy + (
  sizumi * (
    1 + 0 - (
      (
        ( 1-
          (obj.time/(1/tempo*60)) %1
        )
      )^3 
    )
  )
)

obj.aspect =(
  (asp/100) * (
     (
      (
        ( 1-
          (obj.time/(1/tempo*60)) %1
        )
      )^3 
    )
  )
)

if (
  kisuuDesu(
    math.floor(  ( obj.time/(1/tempo*60) )  )
  )
) then
  obj.ry = 180 - (gachideShine(aburi) * 180)
end

