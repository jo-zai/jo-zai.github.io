--track0:ƒeƒ“ƒ|, 1, 1000, 182
--track1:ƒnƒl—ت, -4000, 4000, 60
--track2:‘ه‚«‚³‰ءژZ, 0, 1000, 20
--track3:ƒXƒNƒچپ[ƒ‹•ûŒü, -1, 1, 0, 1
--information:Created by ڈùچك

tempo = obj.track0
hane = obj.track1
zoomscale = obj.track2
scrollvec = obj.track3

local varsan = ((obj.time/(1/tempo*60)%1)-0.5)*10
local scaller = zoomscale / 100

obj.ox = obj.ox+(scrollvec*obj.screen_w*((obj.time / (1/tempo*420))%1))

obj.oy = obj.oy + hane * (
  1 + 0 - (
    (
      ( 1-
        (obj.time/(1/tempo*60)) %1
      )
    )^3 
  )
)

obj.zoom = obj.zoom+(scaller*(
  (
    -0.2*(varsan^2)+5)/5
  )
)

@ƒIپ[ƒg”½“]
